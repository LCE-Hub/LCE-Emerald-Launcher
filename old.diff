 @import "tailwindcss";
 
+
+
 @font-face {
+
   font-family: 'Mojangles';
+
   src: url('/fonts/Mojangles.ttf') format('truetype');
+
   font-weight: normal;
+
   font-style: normal;
+
 }
 
+
+
 .gamepad-connected-indicator {
+
   position: fixed;
+
   bottom: 10px;
+
